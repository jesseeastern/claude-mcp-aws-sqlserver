# Copy this file to .env and fill in your values.
# Then load with: source .env  (or use python-dotenv)

# AWS region where your EC2 instances are located
AWS_REGION=us-east-2

# EC2 instance ID of your Windows SQL Server host
WINDOWS_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# Private VPC IP address of the SQL Server instance
SQL_SERVER_IP=10.0.0.x

# SQL Server port (default: 1433)
SQL_SERVER_PORT=1433

# SQL Server login username
SQL_USER=your_sql_username

# SQL Server login password
SQL_PASSWORD=your_sql_password
